# Public routing endpoint. Use HTTPS in any non-local environment.
COORDINATOR_URL=http://localhost:8787
# 3-64 chars, only letters/numbers/dot/underscore/dash.
NODE_ID=rohan-laptop-01
NODE_DISPLAY_NAME=Rohan's Local AI Node
# At least 16 chars. Matches NODE_BOOTSTRAP_TOKEN during the local demo.
NODE_TOKEN=change-me-before-production
# Ollama must be running locally. Do not expose this endpoint to the internet.
OLLAMA_URL=http://127.0.0.1:11434
# Strict model allow-list. The node never runs a model not listed here.
OLLAMA_MODEL_ALLOWLIST=llama3.2:3b
MAX_CONCURRENT_JOBS=1
MAX_TOKENS_PER_JOB=512
POLL_INTERVAL_MS=1500
HEARTBEAT_INTERVAL_MS=10000
KEYS_DIR=keys
