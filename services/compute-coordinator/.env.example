HOST=127.0.0.1
PORT=8787
DATA_DIR=.data
CORS_ORIGIN=http://localhost:5173,http://localhost:4173
# Development only. Set false in public environments and provision tokens through identity/admin tooling.
DEV_ALLOW_NODE_REGISTRATION=true
# Development only. Production must authenticate requesters server-side.
ALLOW_ANONYMOUS_REQUESTS=true
# Optional single development token for Node Agents when DEV_ALLOW_NODE_REGISTRATION=false.
NODE_BOOTSTRAP_TOKEN=change-me-before-production
NODE_HEARTBEAT_TTL_MS=45000
MAX_PROMPT_ENVELOPE_BYTES=65536
MAX_JOB_TOKENS=1024
MAX_JOBS_PER_MINUTE_PER_IP=6
