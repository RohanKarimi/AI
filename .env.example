# Copy service-specific examples before running each service.
# The web application only enables Community Device when VITE_COMPUTE_API_URL is set.
#
# Docker Compose defaults:
AIOS_WEB_PORT=4173
AIOS_COORDINATOR_PORT=8787

# Local-only on the same machine:
VITE_COMPUTE_API_URL=http://localhost:8787
AIOS_CORS_ORIGIN=http://localhost:4173,http://localhost:5173

# LAN example, replace with your host IP:
# VITE_COMPUTE_API_URL=http://192.168.0.189:8787
# AIOS_CORS_ORIGIN=http://192.168.0.189:4173,http://localhost:4173,http://localhost:5173

# Public domain example, use HTTPS in production:
# VITE_COMPUTE_API_URL=https://api.your-domain.com
# AIOS_CORS_ORIGIN=https://your-domain.com
